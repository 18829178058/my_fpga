# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y20 [get_cells u_pll/inst/clkf_buf]
set_property LOC BUFGCTRL_X0Y18 [get_cells u_pll/inst/clkout4_buf]
set_property LOC BUFGCTRL_X0Y16 [get_cells u_pll/inst/clkout3_buf]
set_property LOC BUFGCTRL_X0Y19 [get_cells u_pll/inst/clkout2_buf]
set_property LOC BUFGCTRL_X0Y17 [get_cells u_pll/inst/clkout1_buf]
set_property LOC BUFGCTRL_X0Y0 [get_cells lcd_clk_OBUF_BUFG_inst]

# Location of IO Primitives which is load of clock spine
set_property LOC IOB_X1Y73 [get_cells lcd_clk_OBUF_inst]
set_property LOC IOB_X1Y93 [get_cells ad_clk_OBUF_inst]

# Location of clock ports
set_property LOC IOB_X1Y76 [get_ports sys_clk]

# Clock net "u_pll/inst/clk_out4" driven by instance "u_pll/inst/clkout4_buf" located at site "BUFGCTRL_X0Y18"
#startgroup
create_pblock {CLKAG_u_pll/inst/clk_out4}
add_cells_to_pblock [get_pblocks  {CLKAG_u_pll/inst/clk_out4}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="u_pll/inst/clk_out4"}]]]
resize_pblock [get_pblocks {CLKAG_u_pll/inst/clk_out4}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0}
#endgroup

# Clock net "u_pll/inst/clk_out2" driven by instance "u_pll/inst/clkout2_buf" located at site "BUFGCTRL_X0Y19"
#startgroup
