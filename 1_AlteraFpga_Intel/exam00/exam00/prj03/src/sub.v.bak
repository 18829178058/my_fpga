module			sub
(
				//减法器参数输入
				input[7:0]			a	//加法器参数a[7:0]
				input[7:0]			b,	//加法器参数b[7:0]
				input[7:0]			c,	//加法器参数c[7:0]
				//减法器输出结果
				output[7:0]			y	//减法器运算结果输出



);

always 			@(*)
				y=  my_func(a,b,c);
/////////////////函数定义///////////////////////////////////
function    [7:0]my_func  ;
//参数定义
input    [7:0] a_tmp;//定义函数参数a_tmp
input    [7:0] b_tmp;//定义函数参数b_tmp
input    [7:0] c_tmp;//定义函数参数b_tmp	
wire  	 [8:0]  sum;
begin
sum   		=     a+b;
my_func     =     sum  -c;
end
endfunction


endmodule 