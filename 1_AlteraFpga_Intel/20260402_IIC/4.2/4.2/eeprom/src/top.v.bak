//项目功能：使用串口对eeprom进行数据读写操作
//帧格式固定，
//帧头+sendnum（写数据字节数）+recvnum（读数据字节数）+worr（方向）+addr_H（地址高8位）+addr_L（地址第八位）+data（数据）+帧尾
module top(clk, rst_n, rx, tx, scl, sda);
	
	input clk, rst_n;
	
	input rx;
	
	output tx;
	
	inout  scl;
	inout  sda;
	
	wire	[7:0]	data_rx;
	wire			rx_done;
	
	uart_rx #(			.CLOCK_FRQ(50_000_000),//时钟频率
							.BAUD	(9600)			,//波特率
							.DATA_LENTH	(8)		,//数据位长度
							.CHECKBIT_SELECT(0)	,//0为无需校验，1为需要校验
							.CHECK_TYPE	(0)		//0为偶校验，1为奇校验
									)		
					rx_inst(
									.clk(clk), 
									.rst_n(rst_n), 
									.uart_rxd(rx), 
									.rx_dout(data_rx), 
									.rx_dout_vld(rx_done)
								);



endmodule 