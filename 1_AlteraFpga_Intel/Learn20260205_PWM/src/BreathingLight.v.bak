module   BreathingLight  //呼吸灯模块周期2s
(
          input           clk,         //系统时钟，50MHz
          input           rst_n,       //系统复位，低电平有效
          output          led_out      //pwm输出，控制led，呈现呼吸效果
);

/////////////////////////5分频//////////////////////////////

reg  clk1,clk2,clk3;
reg [2:0] cnt1;

assign clk3 =clk1 | clk2

always @(posedge clk or negedge rst_n)
			if(rst_n == 1'b0)
			   cnt1 <= 3'b0
			else if(cnt1 == 4)
			   cnt1 <= 3'b0;
			else
               cnt1 <= cnt1 + 1;

always @(posedge clk or negedge rst_n)
			if(rst_n == 1'b0)
			   clk1 <= 1'b0
			else if(cnt1 == 4 || 2)
			   clk1 <= ~clk1;

always @(posedge clk or negedge rst_n)
			if(rst_n == 1'b0)
			   clk2 <= 1'b0
			else if(cnt1 == 4 || 2)
			   clk2 <= ~clk2;

//状态编码
localparam  hu =  2'b00,   //呼
            xi =  2'b01;   //吸

//状态寄存
reg [1:0] state_cs, state_ns
always @(posedge clk or negedge rst_n)
			if(rst_n == 1'b0)
				state_cs <= 2'b00;
			else
				state_cs <= state_ns;

reg [9:0] cnt2, cnt3;
				
//状态转移
always @(*)
			if(rst_n == 1'b0) begin
				state_cs = hu;
				cnt2 = 10'd0;
				cnt3 = 10'd0;
			end else case(state_cs)
				hu:if(cnt2 < 10'd1000)begin
				        if(cnt3 < cnt2)
							 cnt3 = cnt3 + 1'b1;
						else begin
							 cnt3 = 1'b0;
							 cnt2 = cnt2 + 1'b1;
						end
						state_cs = hu;
				   end else
				        state_cs = xi;
						
				xi:if(cnt2 > 10'd0)begin
				        if(cnt3 > cnt2)
							 cnt3 = cnt3 - 1'b1;
						else begin
							 cnt3 = 10'd1000;
							 cnt2 = cnt2 - 1'b1;
						end
						state_cs = xi;
				   end else
				        state_cs = hu;
						
				default: state_cs = hu;
            endcase


assign led_out = cnt3? 1'b0 : 1'b1;

endmodule