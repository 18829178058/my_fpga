module

	reg clk;
	reg rst_n;
	reg [3:0] key_data;
	reg flag;			//按键使能信号，1代表按键按下
	
	initial
		begin
			clk = 0;
			rst_n = 0;
			#53 rst_n = 1;
			
		end
	
	always #10 clk = ~clk;
	
	initial
		begin
			#1000000	key_data = 1;
			#1000000	key_data = 2;
		end
	
	

	wire dout;

cal	cal_inst
(
	.clk(),
	.rst_n(),
	.key_data(),
	.flag(),			//按键使能信号，1代表按键按下
	.dout()
);


endmodule