module fifo_wr
(
	input clk,
	input rst_n,
	input wr_empty,  			//空满信号
	input wr_full,
	output reg [7:0] data,		//写数据
	output reg wr_req			//写请求
);

	reg [1:0] state;
	parameter	EMPTY	=	1'b0;		//检测空信号状态
				FULL 	=	1'b1;		//检测满信号状态

always@(posedge clk or negedge rst_n)
begin
	if(!rst_n)
		begin
			state <= 1'b0;
			wr_req <= 1'b0;
			data <= 8'b0;
		end
	else
		case(state)
			EMPTY:	begin
						if(wr_empty)
							state <= FULL;		//FIFO已空，开始写
						else
							state <= EMPTY;		//等待空
					end
			FULL:	begin
						if(wr_full)
							begin
								data <= 8'b0;	//FIFO已满，停止写
								wr_req <= 1'b0;
								state <= EMPTY;
							end
						else
							begin
								data <= data + 1'b1;	//FIFO未满，继续写
								wr_req <= 1'b1;
								state <= FULL;	
							end
					end
			default: state <= 0;
		endcase
end

endmodule