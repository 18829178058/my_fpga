//按键加减控制
/*--------------------------顶层端口声明--------------------------------*/
module adjust_ctrl(clk, rst_n, key_sel, key_a, key_f_add, key_f_sub, wave_f, wave_a, wave_sel);

	input clk, rst_n;
	
	input key_sel, key_a, key_f_add, key_f_sub;//波形，幅度，频率加，频率减
	
	output	reg	[2:0] wave_a;	//幅度值
	
	output	reg	[13:0]	wave_f;	//频率值
	
	output	reg	[1:0]	wave_sel;	//当前波形
	
/*--------------------------内部参数声明--------------------------------*/	

	parameter	F_IDLE	=	100;	//频率初始值
	parameter	F_STEP	=	100;	//频率步进
	parameter	A_IDLE	=	1;		//幅度初始值
	parameter	A_STEP	=	1;		//幅度步进

/*--------------------------内部变量定义--------------------------------*/	

	reg	[13:0]	wave_f1, wave_f2, wave_f3, wave_f4;	//四个波形分别寄存的频率
	
	reg	[2:0]		wave_a1, wave_a2, wave_a3, wave_a4;	//四个波形分别寄存的幅度
	
/*--------------------------频率加减--------------------------------*/		
//wave_f1
	always @ (posedge clk, negedge rst_n)
		begin
			if(!rst_n)
				wave_f1 <= F_IDLE;
			else
				if(wave_sel == 2'b00)
					if(key_f_add == 1)
						if(wave_f1 < 13'd99900)
							wave_f1 <= wave_f1 + F_STEP;
						else
							wave_f1 <= F_IDLE;
					else
						if(key_f_sub == 1)
							if(wave_f1 > F_IDLE)
								wave_f1 <= wave_f1 - F_STEP;
							else
								wave_f1 <= 13'd99900;
						else
							wave_f1 <= wave_f1;
				else
					wave_f1 <= wave_f1;
		end

//wave_f2
	always @ (posedge clk, negedge rst_n)
		begin
			if(!rst_n)
				wave_f2 <= F_IDLE;
			else
				if(wave_sel == 2'b01)
					if(key_f_add == 1)
						if(wave_f2 < 13'd99900)
							wave_f2 <= wave_f2 + F_STEP;
						else
							wave_f2 <= F_IDLE;
					else
						if(key_f_sub == 1)
							if(wave_f2 > F_IDLE)
								wave_f2 <= wave_f2 - F_STEP;
							else
								wave_f2 <= 13'd99900;
						else
							wave_f2 <= wave_f2;
				else
					wave_f2 <= wave_f2;
		end
		
//wave_f3
	always @ (posedge clk, negedge rst_n)
		begin
			if(!rst_n)
				wave_f3 <= F_IDLE;
			else
				if(wave_sel == 2'b10)
					if(key_f_add == 1)
						if(wave_f3 < 13'd99900)
							wave_f3 <= wave_f3 + F_STEP;
						else
							wave_f3 <= F_IDLE;
					else
						if(key_f_sub == 1)
							if(wave_f3 > F_IDLE)
								wave_f3 <= wave_f3 - F_STEP;
							else
								wave_f3 <= 13'd99900;
						else
							wave_f3 <= wave_f3;
				else
					wave_f3 <= wave_f3;
		end

//wave_f4
	always @ (posedge clk, negedge rst_n)
		begin
			if(!rst_n)
				wave_f4 <= F_IDLE;
			else
				if(wave_sel == 2'b11)
					if(key_f_add == 1)
						if(wave_f4 < 13'd99900)
							wave_f4 <= wave_f4 + F_STEP;
						else
							wave_f4 <= F_IDLE;
					else
						if(key_f_sub == 1)
							if(wave_f4 > F_IDLE)
								wave_f4 <= wave_f4 - F_STEP;
							else
								wave_f4 <= 13'd99900;
						else
							wave_f4 <= wave_f4;
				else
					wave_f4 <= wave_f4;
		end
	
/*--------------------------幅度加减--------------------------------*/
//wave_a1
	always @ (posedge clk, negedge rst_n)
		begin
			if(!rst_n)
				begin
					wave_a1 <= A_IDLE;
				end
			else
				if(wave_sel == 2'b00)
					if(key_a == 1)
						if(wave_a1 < 3'd5)
							wave_a1 <= wave_a1 + A_STEP;
						else
							wave_a1 <= A_IDLE;
					else
						wave_a1 <= wave_a1;
				else
					wave_a1 <= wave_a1;
		end

//wave_a2
	always @ (posedge clk, negedge rst_n)
		begin
			if(!rst_n)
				begin
					wave_a2 <= A_IDLE;
				end
			else
				if(wave_sel == 2'b01)
					if(key_a == 1)
						if(wave_a2 < 3'd5)
							wave_a2 <= wave_a2 + A_STEP;
						else
							wave_a2 <= A_IDLE;
					else
						wave_a2 <= wave_a2;
				else
					wave_a2 <= wave_a2;
		end

//wave_a3
	always @ (posedge clk, negedge rst_n)
		begin
			if(!rst_n)
				begin
					wave_a3 <= A_IDLE;
				end
			else
				if(wave_sel == 2'b10)
					if(key_a == 1)
						if(wave_a3 < 3'd5)
							wave_a3 <= wave_a3 + A_STEP;
						else
							wave_a3 <= A_IDLE;
					else
						wave_a3 <= wave_a3;
				else
					wave_a3 <= wave_a3;
		end

//wave_a4
	always @ (posedge clk, negedge rst_n)
		begin
			if(!rst_n)
				begin
					wave_a4 <= A_IDLE;
				end
			else
				if(wave_sel == 2'b11)
					if(key_a == 1)
						if(wave_a4 < 3'd5)
							wave_a4 <= wave_a4 + A_STEP;
						else
							wave_a4 <= A_IDLE;
					else
						wave_a4 <= wave_a4;
				else
					wave_a4 <= wave_a4;
		end


endmodule 