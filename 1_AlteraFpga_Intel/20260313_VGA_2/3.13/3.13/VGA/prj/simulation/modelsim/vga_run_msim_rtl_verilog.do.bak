	vdel -lib rtl_work -all
}
vlib rtl_work
vmap work rtl_work

vlog -vlog01compat -work work +incdir+C:/Users/dell/Desktop/ZX/3.13/VGA/ip {C:/Users/dell/Desktop/ZX/3.13/VGA/ip/vga_pll.v}
vlog -vlog01compat -work work +incdir+C:/Users/dell/Desktop/ZX/3.13/VGA/src {C:/Users/dell/Desktop/ZX/3.13/VGA/src/top.v}
