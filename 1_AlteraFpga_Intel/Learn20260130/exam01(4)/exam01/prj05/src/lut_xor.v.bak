module			lut_xor
(
				input		a,//异或门异或信号a
				input		b,//异或门异或信号b
				output		c //异或门异或结果输出信号c

);
wire			not0,not1;

//////////////////非门例化////////////////////////////////////////
lut_not			lut_not_ins0//定义元件lut_not_ins0
//端口映射，顺序映射
(
				.a(b),//非门输入信号,与a信号连接
				.c(not0)//非门输出信号，与not0信号连接
);
lut_not			lut_not_ins1//定义元件lut_not_ins1
//端口映射，顺序映射
(
				.a(a),//非门输入信号,与a信号连接
				.c(not1)//非门输出信号，与not0信号连接
);
//////////////////与门例化////////////////////////////////////////
wire			   and0,and1;
lut_and			lut_and_ins0//定义元件lut_and_ins0
//端口映射，顺序映射
(
				//与门输入
				.a(a),	/*与门输入信号
				0：按下
				1：未被按下*/
				.b(not0),	/*与门输入信号
				0：按下
				1：未被按下*/
				//与门输出
				.c(and0)	//与门输出
);
lut_and			lut_and_ins1//定义元件lut_and_ins1
//端口映射，顺序映射
(
				//与门输入
				.a(b),	/*与门输入信号
				0：按下
				1：未被按下*/
				.b(not1),	/*与门输入信号
				0：按下
				1：未被按下*/
				//与门输出
				.c(and1)	//与门输出
);
//////////////////或门例化////////////////////////////////////////
lut_or			lut_or_ins//定义元件lut_or_ins
(
				//与门输入
				.a(and0),	/*与门输入信号
				0：按下
				1：未被按下*/
				.b(and1),	/*与门输入信号
				0：按下
				1：未被按下*/
				//与门输出
				.c(c)	//与门输出
);
endmodule 