`timescale 1ns/1ps

module test_bench;

	reg 	clk_in;  	 //系统时钟
	reg 	rst_n;  	 //系统复位
	reg   keySwitch;   //按键切换歌曲
	reg   keyPause;   //按键暂停歌曲
	wire	 beezer;
	
	music_player dut(
			 .clk_in(clk_in),  	 //系统时钟
			 .rst_n(rst_n),  	 //系统复位
			 .keySwitch(keySwitch),   //按键切换歌曲
			 .keyPause(keyPause),   //按键暂停歌曲
			 .beezer(beezer)  	 //蜂鸣器控制输出
	);
	
	initial begin
	clk_in = 0; rst_n = 0;
	
	#100 rst_n =1;
	
	end
	
	always #10 clk_in = ~clk_in;


endmodule